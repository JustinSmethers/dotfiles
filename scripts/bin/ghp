#!/usr/bin/env bash
set -euo pipefail

echo "Fetching and pruning remote branches..."
git fetch --prune

echo "Finding stale local branches..."
STALE=$(git branch -vv | awk '/: gone]/{print $1 == "*" ? $2 : $1}')

if [[ -z "$STALE" ]]; then
    echo "No stale branches found."
    exit 0
fi

echo "Deleting stale branches:"
echo "$STALE"
while IFS= read -r branch; do
    git branch -d "$branch"
done <<< "$STALE"
